---
import { Image } from "astro:assets";
import type { CollectionEntry } from "astro:content";

type Props = {
    project: CollectionEntry<"projects">;
};

// const [uno, dos, tres, cuatro] = [1, 2, 3, 4]

// const {age, name, sex} =  {
//     name: 'Gabriel',
//     age: 20,
//     sex: 'Femenino',
// }

const { project } = Astro.props;

const {
    body,
    data: { title, image, stack },
} = project;
---

<div class="post">
    <Image
        src={`/projects/${image}`}
        alt={`Screenshot de ${title}`}
        width={500}
        height={500}
        class="post__image"
    />

    <div class="post__content">
        <h3 class="post__title">
            {title}
        </h3>

        <div class="post__stack">
            {stack.map((item) => (
                <span class="post__stack-item">
                    {item}
                </span>
            ))}
        </div>

        <p class="post__text">
            {body.substring(0, 250)}...
        </p>
    </div>
</div>

<style>
    .post {
        display: flex;
        gap: 2rem;
        flex-direction: column;
    }

    @media (width >= 768px){
        .post {
            flex-direction: row;
        }
    }

    .post__image {
        width: 100%;
        margin: 0 auto;
        max-width: 50rem;
        height: auto;
        aspect-ratio: 16/9;
        object-fit: cover;
        border-radius: 1rem;
    }

    @media (width >= 768px){
        .post__image {
            max-width: 30rem;
        }
    }

    @media (width >= 992px){
        .post__image {
            max-width: 45rem;
        }
    }

    .post__content {
        flex: 1;
        display: flex;
        flex-direction: column;
    }

    .post__title {
        margin: 1rem 0;
        color: var(--color-primary-800);
    }

    .post__title::after {
        content: '';
        display: block;
        width: 100%;
        height: 0.4rem;
        border-radius: 0.2rem;
        background-color: var(--color-primary-600);
    }

    .post__stack {
        display: flex;
        flex-wrap: wrap;
        gap: 0.5rem;
    }

    .post__stack-item {
        padding: 0.5rem 1rem;
        background-color: var(--color-primary-600);
        color: var(--color-white);
        border-radius: 0.4rem;
        font-size: 1.4rem;
        font-weight: bold;
    }

    .post__text {
        margin-top: 2rem;
        text-wrap: pretty;
        line-height: 1.5;
        font-size: 1.8rem;
        white-space: pre-line;
    }
</style>
